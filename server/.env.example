# Runtime environment
NODE_ENV="development"
PORT="4000"
JSON_BODY_LIMIT="100kb"
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX="20"
MUTATION_RATE_LIMIT_WINDOW_MS="60000"
MUTATION_RATE_LIMIT_MAX="120"

# Database connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gms_dev?schema=public"
REDIS_URL="redis://localhost:6379"
DASHBOARD_CACHE_TTL_SEC="45"
SLO_LATENCY_P95_MS="300"
SLO_ERROR_RATE_PCT="1"

# JWT configuration
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# Admin seed configuration
ADMIN_NAME="System Admin"
ADMIN_EMAIL="admin@fitnessgarage.local"
ADMIN_PASSWORD="ChangeMe123!"

# Optional invite codes for role-based self-registration
# Keep empty to disable self-registration for that role.
TRAINER_INVITE_CODE=""
ADMIN_INVITE_CODE=""
